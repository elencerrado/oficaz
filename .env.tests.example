# Copy this file to .env.visual.test (or .env.test) and fill with real test users.
# IMPORTANT: never commit real credentials.

# Base URL used by visual and smoke tests
TIME_VISUAL_BASE_URL=http://localhost:5000
TIME_SMOKE_BASE_URL=http://localhost:5000

# Option A (recommended): Use login credentials for visual tests
TIME_VISUAL_EMPLOYEE_LOGIN=
TIME_VISUAL_EMPLOYEE_PASSWORD=
TIME_VISUAL_EMPLOYEE_COMPANY_ALIAS=
TIME_VISUAL_ADMIN_LOGIN=
TIME_VISUAL_ADMIN_PASSWORD=
TIME_VISUAL_ADMIN_COMPANY_ALIAS=

# Option B: Use already-issued JWT tokens for visual tests
# TIME_VISUAL_EMPLOYEE_TOKEN=
# TIME_VISUAL_ADMIN_TOKEN=

# Option A (recommended): Use login credentials for API smoke tests
TIME_SMOKE_EMPLOYEE_LOGIN=
TIME_SMOKE_EMPLOYEE_PASSWORD=
TIME_SMOKE_EMPLOYEE_COMPANY_ALIAS=
TIME_SMOKE_ADMIN_LOGIN=
TIME_SMOKE_ADMIN_PASSWORD=
TIME_SMOKE_ADMIN_COMPANY_ALIAS=

# Option B: Use already-issued JWT tokens for API smoke tests
# TIME_SMOKE_EMPLOYEE_TOKEN=
# TIME_SMOKE_ADMIN_TOKEN=
